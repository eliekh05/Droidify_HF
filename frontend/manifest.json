  "share_target": {
    "action": "/devices.html",
    "method": "GET",
    "params": {
      "title": "q",
      "text": "q",
      "url": "q"
    },
    "enctype": "application/x-www-form-urlencoded"
  },
  "file_handlers": [
    {
      "action": "/devices.html",
      "accept": {
        "application/zip": [
          ".zip"
        ],
        "application/octet-stream": [
          ".img",
          ".bin"
        ]
      },
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "scope_extensions": [],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "related_applications": [],
  "permissions": [
    "periodic-background-sync"
  ],
  "protocol_handlers": [
    {
      "protocol": "web+droidify",
      "url": "/devices.html?q=%s"
    }
  ]
